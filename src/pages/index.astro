---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Base
  title="Shieldz Blog: non-custodial crypto payments"
  description="Engineering and product writing from the team building Shieldz, the non-custodial crypto payment processor with $0 platform fees."
>
  <h1>Shieldz Blog</h1>
  <p class="meta">Non-custodial crypto payments, written by the people building it.</p>
  <ul class="post-list">
    {
      posts.map((p) => (
        <li>
          <h2><a href={`${base}/${p.id}`}>{p.data.title}</a></h2>
          <p class="meta">
            {p.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </p>
          <p>{p.data.description}</p>
        </li>
      ))
    }
  </ul>
</Base>
