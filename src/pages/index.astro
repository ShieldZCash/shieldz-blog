---
import Base from "../layouts/Base.astro";
import { getCollection } from "astro:content";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Base
  title="Shieldz Blog: non-custodial crypto payments"
  description="Engineering and product writing from the team building Shieldz, the non-custodial crypto payment processor with $0 platform fees."
>
  <h1>Shieldz Blog</h1>
  <p class="meta">Non-custodial crypto payments, written by the people building it.</p>
  <ul class="post-list">
    {
      posts.map((p) => (
        <li>
          <h2><a href={`${base}/${p.id}`}>{p.data.title}</a></h2>
          <p class="meta">
            {p.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
          </p>
          <p>{p.data.description}</p>
        </li>
      ))
    }
  </ul>

  <h2>Guides &amp; resources</h2>
  <p class="meta">Everything to get paid in crypto with Shieldz.</p>

  <h3>Accept a coin</h3>
  <p>
    <a href="https://shieldz.cash/accept-bitcoin">Bitcoin</a> &middot;
    <a href="https://shieldz.cash/accept-usdc">USDC</a> &middot;
    <a href="https://shieldz.cash/accept-usdt">USDT</a> &middot;
    <a href="https://shieldz.cash/accept-zcash">Zcash</a>
  </p>

  <h3>Payments on a chain</h3>
  <p>
    <a href="https://shieldz.cash/crypto-payments-on-base">Base</a> &middot;
    <a href="https://shieldz.cash/crypto-payments-on-arbitrum">Arbitrum</a> &middot;
    <a href="https://shieldz.cash/crypto-payments-on-optimism">Optimism</a> &middot;
    <a href="https://shieldz.cash/crypto-payments-on-polygon">Polygon</a> &middot;
    <a href="https://shieldz.cash/crypto-payments-on-ethereum">Ethereum</a>
  </p>

  <h3>Integration guides</h3>
  <p>
    <a href="https://shieldz.cash/accept-crypto-nextjs">Next.js</a> &middot;
    <a href="https://shieldz.cash/accept-crypto-express">Express</a> &middot;
    <a href="https://shieldz.cash/accept-crypto-laravel">Laravel</a> &middot;
    <a href="https://shieldz.cash/accept-crypto-django">Django</a> &middot;
    <a href="https://shieldz.cash/accept-crypto-rails">Rails</a>
  </p>

  <h3>Compare</h3>
  <p>
    <a href="https://shieldz.cash/vs-coinbase-commerce">vs Coinbase Commerce</a> &middot;
    <a href="https://shieldz.cash/vs-btcpay">vs BTCPay</a> &middot;
    <a href="https://shieldz.cash/vs-cryptapi">vs CryptAPI</a> &middot;
    <a href="https://shieldz.cash/vs-nowpayments">vs NOWPayments</a> &middot;
    <a href="https://shieldz.cash/crypto-payment-fees">fee comparison</a>
  </p>

  <h3>Use cases</h3>
  <p>
    <a href="https://shieldz.cash/for-freelancers">Freelancers</a> &middot;
    <a href="https://shieldz.cash/for-creators">Creators</a> &middot;
    <a href="https://shieldz.cash/for-open-source">Open source</a> &middot;
    <a href="https://shieldz.cash/for-ecommerce">E-commerce</a>
  </p>

  <h3>Reference</h3>
  <p>
    <a href="https://shieldz.cash/sdks">SDKs</a> &middot;
    <a href="https://shieldz.cash/docs">API docs</a> &middot;
    <a href="https://shieldz.cash/reference">API reference</a> &middot;
    <a href="https://shieldz.cash/glossary">Glossary</a> &middot;
    <a href="https://shieldz.cash/introducing-shieldz">Overview</a> &middot;
    <a href="https://shieldz.cash/is-shieldz-legit">Is Shieldz legit?</a> &middot;
    <a href="https://shieldz.cash/trust">Is it safe?</a> &middot;
    <a href="https://shieldz.cash/verify">Verify it yourself</a>
  </p>
</Base>
